```gitignore
# Build artifacts and binaries
*.dll
*.exe
*.pdb
*.obj
*.o
*.so
*.a
*.class
*.pyc
__pycache__/

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# IDE specific
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution / packaging
dist/
build/
target/
.gradle/

# Python cache
.mypy_cache/
.pytest_cache/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
```